modules = ["python-3.12", "web", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
DEBUG = "true"
DJANGO_SECRET_KEY = "django-insecure-replit-dev-key-change-in-production"
CORS_ALLOWED_ORIGINS = "http://localhost:5000,http://0.0.0.0:5000,https://d0bbf1db-5c67-4d99-a6b2-d15e99c41293-00-1zw9jdvgmuwmz.spock.replit.dev"
FRONTEND_URL = "http://localhost:5000"
API_BASE_URL = "http://localhost:8000"
TEST_MODE = "true"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py runserver 0.0.0.0:8000"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd landrify_frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd landrify_frontend && npm run preview -- --port 5000 --host 0.0.0.0 & python manage.py runserver 0.0.0.0:8000"]
build = ["bash", "-c", "pip install -r requirements.txt && cd landrify_frontend && npm install && npm run build && cd .. && python manage.py collectstatic --noinput && python manage.py migrate"]
